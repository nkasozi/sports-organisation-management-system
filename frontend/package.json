{
  "name": "sports-organisation-frontend",
  "version": "1.0.0",
  "description": "Frontend for Sport-Sync",
  "type": "module",
  "scripts": {
    "dev": "vite dev --host",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:fail": "vitest run --silent",
    "test:watch": "vitest",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint . --max-warnings=0",
    "format": "eslint . --fix && prettier --write .",
    "knip": "knip"
  },
  "devDependencies": {
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-svelte": "^2.36.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "knip": "^5.88.1",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.0.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@clerk/clerk-js": "^6.0.0",
    "@faker-js/faker": "^9.9.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@schedule-x/calendar": "^3.7.3",
    "@schedule-x/drag-and-drop": "^3.7.3",
    "@schedule-x/event-modal": "^4.1.0",
    "@schedule-x/theme-default": "^4.1.0",
    "@vercel/analytics": "^1.3.2",
    "convex": "^1.31.7",
    "dexie": "^4.3.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "svelte-clerk": "^1.1.2",
    "temporal-polyfill": "^0.3.0"
  },
  "knip": {
    "ignoreFiles": [
      "static/sw-register.js",
      "static/sw.js",
      "static/theme-init.js"
    ],
    "ignoreIssues": {
      "src/lib/presentation/components/EntityCrudWrapper.svelte": [
        "exports"
      ],
      "src/lib/presentation/components/EntityCrudWrapperContent.svelte": [
        "exports"
      ]
    }
  }
}
